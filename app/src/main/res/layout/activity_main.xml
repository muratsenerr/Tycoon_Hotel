<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".MainActivity">

    <!-- Üst Kontrol Paneli -->
    <LinearLayout
        android:id="@+id/topControlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:paddingTop="32dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Kasa ve Yemek Bilgisi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingBottom="8dp"
            android:gravity="center">

            <TextView
                android:id="@+id/txtTotalMoney"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kasa: 50.00 $"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="start" />

            <TextView
                android:id="@+id/txtFoodStock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Yemek: 0"
                android:textColor="#FF9800"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="end"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Yeni Kat Al Butonu -->
        <Button
            android:id="@+id/btnBuyFloor"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:text="YENİ KAT AL"
            android:textSize="18sp"
            android:backgroundTint="#6200EE"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- Kat Listesi (RecyclerView) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewFloors"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topControlPanel" />

    <!-- Görevler Butonu (Sağ Orta) -->
    <FrameLayout
        android:id="@+id/btnQuests"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/circle_background"
        android:backgroundTint="#FFC107"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/txtQuestCount"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="top|end"
            android:background="@drawable/circle_background"
            android:backgroundTint="#F44336"
            android:gravity="center"
            android:text="2"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:textStyle="bold" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
